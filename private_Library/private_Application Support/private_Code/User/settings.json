{
	"extensions.experimental.affinity": {
		"vscodevim.vim": 1
	},
	"vim.showMarksInGutter": true,
	"vim.smartRelativeLine": true,
	"vim.leader": "<space>",
	"vim.substitutionTextColor": "#CBA6F7",
	"vim.enableNeovim": true,
	"vim.camelCaseMotion.enable": true,
	"vim.normalModeKeyBindingsNonRecursive": [
		// by szw
		{
			"before": ["x"],
			"after": ["\"", "_", "x"]
		},
		{
			"before": ["<leader>", "d"],
			"after": ["\"", "_", "d"]
		},
		{
			"before": ["H"],
			"commands": ["workbench.action.previousEditor"],
			"silent": true
		},
		{
			"before": ["L"],
			"commands": ["workbench.action.nextEditor"],
			"silent": true
		},
		{
			"before": ["<leader>", "/"],
			"commands": ["search.action.openEditor"],
			"silent": true
		},
		{
			"before": ["<leader>", "f", "g"],
			"commands": ["workbench.action.quickTextSearch"],
			"silent": true
		},
		{
			"before": ["<leader>", "f", "d"],
			"commands": ["workbench.action.problems.focus"],
			"silent": true
		},
		{
			"before": ["<leader>", "f", "s"],
			"commands": ["workbench.action.gotoSymbol"],
			"silent": true
		},
		{
			"before": ["<leader>", "f", "f"],
			"commands": ["workbench.action.quickOpen"],
			"silent": true
		},
		{
			"before": ["<leader>", "a"],
			"commands": ["editor.action.quickFix"],
			"silent": true
		},
		{
			"before": ["<leader>", "r"],
			"commands": ["editor.action.rename"],
			"silent": true
		},
		{
			"before": ["g", "r"],
			"commands": ["editor.action.goToReferences"],
			"silent": true
		},
		{
			"before": ["g", "p", "d"],
			"commands": ["editor.action.peekDefinition"],
			"silent": true
		},
		{
			"before": ["g", "p", "r"],
			"commands": ["editor.action.referenceSearch.trigger"],
			"silent": true
		},
		{
			"before": ["g", "d"],
			"commands": ["editor.action.revealDefinition"],
			"silent": true
		},
		{
			"before": ["c-w", "g", "d"],
			"commands": ["editor.action.revealDefinitionAside"],
			"silent": true
		},
		{
			"before": ["c-i"],
			"commands": ["workbench.action.navigateForwardInNavigationLocations"],
			"silent": true
		},
		{
			"before": ["c-o"],
			"commands": ["workbench.action.navigateBackInNavigationLocations"],
			"silent": true
		},
		{
			"before": ["g", ","],
			"commands": ["workbench.action.navigateForwardInEditLocations"],
			"silent": true
		},
		{
			"before": ["g", ";"],
			"commands": ["workbench.action.navigateBackInEditLocations"],
			"silent": true
		},
		{
			"before": ["<leader>", "="],
			"commands": ["editor.action.formatDocument"],
			"silent": true
		},
		{
			"before": ["[", "c"],
			"commands": [
				"workbench.action.editor.previousChange",
				"workbench.action.compareEditor.previousChange"
			],
			"silent": true
		},
		{
			"before": ["]", "c"],
			"commands": [
				"workbench.action.editor.nextChange",
				"workbench.action.compareEditor.nextChange"
			],
			"silent": true
		},
		{
			"before": ["[", "d"],
			"commands": ["editor.action.marker.prev"],
			"silent": true
		},
		{
			"before": ["]", "d"],
			"commands": ["editor.action.marker.next"],
			"silent": true
		},
		{
			"before": ["<leader>", "n"],
			"commands": ["workbench.explorer.fileView.focus"],
			"silent": true
		},
		{
			"before": ["K"],
			"commands": ["editor.action.showHover"],
			"silent": true
		},
		{
			"before": ["g", "l"],
			"commands": ["editor.action.addSelectionToNextFindMatch"],
			"silent": true
		},
		{
			"before": ["g", "L"],
			"commands": ["editor.action.addSelectionToPreviousFindMatch"],
			"silent": true
		},
		{
			"before": ["d", "o"],
			"commands": ["git.diff.stageHunk"],
			"silent": true
		}
	],
	"vim.insertModeKeyBindingsNonRecursive": [
		{
			"before": ["c-j"],
			"commands": ["editor.action.triggerSuggest"],
			"silent": true
		},
		{
			"before": ["c-k"],
			"commands": ["editor.action.triggerParameterHints"],
			"silent": true
		},
		{
			"before": ["c-v"],
			"commands": ["editor.action.clipboardPasteAction"],
			"silent": true
		}
	],
	"vim.visualModeKeyBindingsNonRecursive": [
		{
			"before": ["g", "l"],
			"commands": ["editor.action.addSelectionToNextFindMatch"],
			"silent": true
		},
		{
			"before": ["g", "L"],
			"commands": ["editor.action.addSelectionToPreviousFindMatch"],
			"silent": true
		},
		{
			"before": ["c-c"],
			"commands": ["editor.action.clipboardCopyAction"],
			"silent": true
		},
		{
			"before": [">"],
			"commands": ["editor.action.indentLines"],
			"silent": true
		},
		{
			"before": ["<"],
			"commands": ["editor.action.outdentLines"],
			"silent": true
		},
		{
			"before": ["J"],
			"commands": ["editor.action.moveLinesDownAction"],
			"silent": true
		},
		{
			"before": ["K"],
			"commands": ["editor.action.moveLinesUpAction"],
			"silent": true
		}
    ],
	"workbench.iconTheme": "material-icon-theme",
	"editor.fontFamily": "Maple Mono NF CN"
}
