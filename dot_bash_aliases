function trim() {
    awk '{$1=$1}1' "$@"
}

function vimd() {
    vim "+set filetype=objdump" "$@"
}

function gd() {
    gdb -x ~/.config/gdbinit "$@"
}

function ii() {
    xdg-open "$@"
}

# fork bomb :(){:|:&};:
#
# gdb tmux
function gdt() {
    local id
    id="$(tmux split-pane -hPF "#D" "tail -f /dev/null")"
    tmux last-pane
    local tty
    tty="$(tmux display-message -p -t "$id" '#{pane_tty}')"
    gd -ex "dashboard source -output $tty" -ex "dashboard source -style height 0" "$@"
    tmux kill-pane -t "$id"
}

function br {
    local cmd cmd_file
    cmd_file=$(mktemp)
    if broot --outcmd "$cmd_file" "$@"; then
        cmd=$(<"$cmd_file")
        eval "$cmd"
    fi
    command rm -f "$cmd_file"
}

function y() {
    local tmp cwd
    tmp=$(mktemp -t "yazi-cwd.XXXXXX")
    yazi "$@" --cwd-file="$tmp"
    IFS= read -r -d '' cwd <"$tmp"
    [ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
    rm -f -- "$tmp"
}

function set_proxy() {
    local port=$1
    if [ -z "$port" ]; then
        port=10808
    fi
    export http_proxy="http://127.0.0.1:${port}"
    export https_proxy="http://127.0.0.1:${port}"
    export all_proxy="http://127.0.0.1:${port}"
}

# tealdeer with vim
function tv() {
    command tldr -r "$@" | vim "+set filetype=markdown" -
}

# set gdb attach capbility
function set_ptrace() {
    echo 0 | sudo tee /proc/sys/kernel/yama/ptrace_scope
}

